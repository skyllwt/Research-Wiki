# Research Wiki — Environment Variables

# Semantic Scholar API Key (optional, recommended when wiki > 100 papers)
# Get yours at https://www.semanticscholar.org/product/api#api-key
S2_API_KEY=

# arXiv categories to monitor (comma-separated, default: cs.LG,cs.CV,cs.CL,cs.AI,stat.ML)
# ARXIV_CATEGORIES=cs.LG,cs.CV,cs.CL,cs.AI
